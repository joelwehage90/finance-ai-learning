# ============================================================
# Excel Add-in Backend — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
#
# SECURITY: dev_mode now defaults to False. You MUST set
# DEV_MODE=true explicitly for local development.

# --- Dev mode (default: false) ---
# When true, the auth dependency is bypassed and the global
# provider is used directly. NEVER set true in production.
DEV_MODE=true

# --- Fortnox OAuth credentials ---
FORTNOX_CLIENT_ID=your-client-id
FORTNOX_CLIENT_SECRET=your-client-secret
FORTNOX_TENANT_ID=your-tenant-id

# ============================================================
# PRODUCTION ONLY — not needed for local development
# ============================================================

# --- Database ---
# PostgreSQL connection string (asyncpg driver).
# For docker-compose: postgresql+asyncpg://postgres:postgres@db:5432/excel_addin
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/excel_addin

# --- JWT ---
# Secret for signing session JWTs. MUST be a strong random string in production.
# The app will REFUSE TO START without this when DEV_MODE=false.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# JWT_SECRET=change-me-in-production
# JWT_EXPIRY_HOURS=24

# --- Token encryption ---
# AES-256-GCM key for encrypting stored OAuth tokens (base64-encoded, 32 bytes).
# The app will REFUSE TO START without this when DEV_MODE=false.
# Generate with: python3 -c "import base64, os; print(base64.b64encode(os.urandom(32)).decode())"
# TOKEN_ENCRYPTION_KEY=

# --- CORS ---
# Comma-separated list of additional allowed origins for production frontend.
# ALLOWED_ORIGINS=https://your-addin.vercel.app

# --- Redirect URI whitelist ---
# Comma-separated list of allowed OAuth redirect URIs in production.
# Localhost URIs are always allowed for development.
# ALLOWED_REDIRECT_URIS=https://your-addin.vercel.app/callback.html
