<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:type="TaskPaneApp">

  <!-- Unique add-in ID — do NOT change after AppSource submission -->
  <Id>d988c7be-71bb-48f6-8a92-d88c2130b76a</Id>
  <Version>0.2.0</Version>
  <ProviderName>Joel Wehage</ProviderName>
  <DefaultLocale>sv-SE</DefaultLocale>
  <DisplayName DefaultValue="Bokföring → Excel" />
  <Description DefaultValue="Hämta rapporter och fakturor från ditt bokföringssystem direkt till Excel. Stöd för Fortnox med fler på väg." />
  <!--
    DEPLOYMENT: Replace YOUR_DOMAIN with the production URL where the
    frontend is hosted (e.g. your-addin.vercel.app). Icons must be
    served over HTTPS from that domain.
  -->
  <IconUrl DefaultValue="https://YOUR_DOMAIN/assets/icon-32.png" />
  <HighResolutionIconUrl DefaultValue="https://YOUR_DOMAIN/assets/icon-64.png" />

  <SupportUrl DefaultValue="https://github.com/" />

  <Hosts>
    <Host Name="Workbook" />
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="DialogApi" MinVersion="1.1" />
    </Sets>
  </Requirements>

  <!--
    DEPLOYMENT: Replace YOUR_DOMAIN with the production URL where
    the built frontend (dist/) is served.
  -->
  <DefaultSettings>
    <SourceLocation DefaultValue="https://YOUR_DOMAIN/taskpane.html" />
  </DefaultSettings>

  <Permissions>ReadWriteDocument</Permissions>

</OfficeApp>
