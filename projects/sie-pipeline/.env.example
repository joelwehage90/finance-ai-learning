# Fortnox credentials (same as fortnox-mcp)
FORTNOX_CLIENT_ID=your_client_id
FORTNOX_CLIENT_SECRET=your_client_secret
FORTNOX_TENANT_ID=your_fortnox_tenant_id

# Supabase credentials
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# Tenant UUID (the id from the tenants table in Supabase)
TENANT_UUID=your_tenant_uuid
